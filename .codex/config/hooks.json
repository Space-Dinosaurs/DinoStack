{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(dirname \"$(dirname \"$(realpath \"$HOME/.codex/hooks.json\")\")\")/hooks/risk-reminder.sh\"",
            "statusMessage": "Checking risk classification"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(dirname \"$(dirname \"$(realpath \"$HOME/.codex/hooks.json\")\")\")/hooks/userpromptsubmit.d/020-skill-auto-load-check.sh\"",
            "statusMessage": "Checking skill auto-load"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(dirname \"$(dirname \"$(realpath \"$HOME/.codex/hooks.json\")\")\")/hooks/stop-context-codex.js\"",
            "timeout": 10,
            "statusMessage": "Saving session context"
          }
        ]
      }
    ]
  }
}
