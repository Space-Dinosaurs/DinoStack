# Claude Code - local settings contain secrets
.claude/settings.local.json

# Claude Code runtime state (local-only, leaks absolute paths)
.claude/compression-state.json

# ScheduleWakeup runtime lock (per-session, not shared)
.claude/scheduled_tasks.lock

# Dependencies
node_modules/

# Environment files
.env
.env.local
.env*.local

# OS
.DS_Store
.vercel

# DinoStack IS the methodology, not a consumer of it. Its own .agentic/ runtime
# state — config, per-developer telemetry/session logs, learnings, qa-regressions,
# worktrees, task/loop/event state — is strictly local and never committed. The
# carve-outs that consumer projects use to track this state deliberately do not
# apply to this repo. Root-anchored (leading slash) so it matches only the repo's
# own .agentic/ and never nested template .agentic/ dirs shipped to consumers.
/.agentic/*
# team.yml is committed project intent (cross-harness team topology)
!/.agentic/team.yml

# Generated Kimi per-command skills (built by .kimi/build.sh from content/commands/)
.kimi/skills/*/
!.kimi/skills/agentic-engineering/

# AI assistant adapter directories (local-only, not committed)
.agents/
.goose/

# Claude Code feature worktrees created by the eval harness (ephemeral)
.claude/worktrees/

# Local-only brainstorming / scratchpads
docs/brainstorm/

# Internal self-improvement infrastructure and working docs - kept local, not shipped upstream.
evals/
.github/workflows/corpus-validation.yml
docs/planning/
docs/research/
docs/technical/
docs/operations/
docs/overview/
docs/_archive/session-learnings/

# Stray .agentic/ runtime working dirs created when a command/subagent runs with a non-root cwd.
content/**/.agentic/
!content/templates/.agentic/
!content/templates/.agentic/**

# Local-only scheduling/automation (e.g. DinoStack PR-review launchd job).
# Machine-specific (resolves local binary paths, pins a GitHub identity) and not
# part of the shipped methodology — kept local, never committed upstream.
/automation/

# Pi coding agent generated/project-local state (not adapter-owned)
.pi/taskplane.json
.pi/agents/supervisor.md
.pi/gsd/
.pi/git/
.pi/npm/
__pycache__/
