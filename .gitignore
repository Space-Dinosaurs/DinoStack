# Claude Code - local settings contain secrets
.claude/settings.local.json

# ScheduleWakeup runtime lock (per-session, not shared)
.claude/scheduled_tasks.lock

# Dependencies
node_modules/

# Environment files
.env
.env.local
.env*.local

# OS
.DS_Store
.vercel

# Local agent runtime state is ignored, but committed project-intent config
# (.agentic/config.json) is carved out - it is portable, like qa.md/deploy.md.
# A bare `.agentic/` ignore cannot be overridden by a later negation (git does
# not descend into an ignored directory), so use the `.agentic/*` form and then
# re-ignore the runtime artifacts explicitly.
.agentic/*
!.agentic/config.json
!.agentic/findings.md
.agentic/worktrees/
.agentic/loop-state.json
.agentic/tasks.jsonl
.agentic/batch-state.json
.agentic/events.jsonl
.agentic/events-prev.jsonl
.agentic/learnings.md
.agentic/.activated
.agentic/.meta-divergence-surfaced
.agentic/.meta-divergence-last-sweep
.agentic/wrap.lock
.agentic/learnings-agent.session

# Generated Kimi per-command skills (built by .kimi/build.sh from content/commands/)
.kimi/skills/*/
!.kimi/skills/agentic-engineering/

# AI assistant adapter directories (local-only, not committed)
.agents/
.goose/
.hermes/

# Claude Code feature worktrees created by the eval harness (ephemeral)
.claude/worktrees/

# Local-only brainstorming / scratchpads
docs/brainstorm/

# Eval runner: worktrees are ephemeral per-run; runlog JSONL is per-run detail.
# TSV files under evals/results/ ARE committed (see docs/planning/p2-self-improving-harness.md).
evals/.worktrees/
evals/results/*.runlog.jsonl

# /auto-harness: per-run lock + per-run state. Ledger TSV at
# evals/results/auto-harness.tsv IS committed.
evals/.auto-harness.lock
evals/auto/state/
evals/auto/editor-logs/

# Baseline capture: in-progress sibling file is ephemeral (not committed).
# The completed baseline JSON IS committed.
evals/baselines/*.progress
evals/baselines/*.progress.tmp

# ICL-vs-orchestration eval: per-run result JSON files are generated artifacts.
# Committed results (if any) are explicitly added with git add -f.
evals/icl_vs_orchestration/results/

# Pi coding agent generated/project-local state (not adapter-owned)
.pi/taskplane.json
.pi/agents/supervisor.md
.pi/gsd/
.pi/git/
.pi/npm/
