#!/usr/bin/env python3
"""
Purpose: Interactive first-time setup of `~/.agentic/role-models.yml` (default
         mode). Discovery is ask-user only: the interactive wizard asks the
         user per role; non-interactive writes scalar defaults the user edits.

Public API: agentic-configure [--models a,b,c] [--force]
            [--non-interactive] [--path PATH]
            team (back-compat shim -> agentic-team configure)
            Default mode is interactive: asks the user to accept or override
            a default model for each role and writes the file. `--models`
            feeds an optional ranked suggestion list (comma-separated model
            ids) to pre-fill per-role defaults via agentic-models ranking.
            `--non-interactive` accepts all defaults silently and exits 0.
            `--force` re-runs even if the file already exists.
            Exit code: 0 on success or no-op (file exists, --force not set);
            2 on validation failure.

Upstream deps: bin/agentic-models (optional ranking aid, invoked only when
               --models is supplied);
               bin/_role_spec (normalize_role_spec);
               bin/agentic-team (back-compat team shim target);
               Python 3 stdlib only otherwise.

Downstream consumers: content/commands/init-project.md (Step 6g reuses the
                      same seed-on-first-run logic for install-time).

Failure modes: File exists -> exit 0 without modifying unless --force.
               --models ranking failure -> fall back to sonnet defaults
               (non-fatal; user can type model names by hand).
               team shim: delegates to agentic-team configure, propagates
               exit code.

Performance: A few prompts (interactive) or immediate scalar write
             (non-interactive). No network calls.
"""

from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
from pathlib import Path

# _role_spec lives in the same bin/ directory (no .py extension peer)
import importlib.machinery as _im
import importlib.util as _ilu
_rs_path = Path(__file__).parent / "_role_spec.py"
_rs_loader = _im.SourceFileLoader("_role_spec", str(_rs_path))
_rs_spec = _ilu.spec_from_loader("_role_spec", _rs_loader)
_rs_mod = _ilu.module_from_spec(_rs_spec)  # type: ignore[arg-type]
_rs_loader.exec_module(_rs_mod)
normalize_role_spec = _rs_mod.normalize_role_spec
KNOWN_HARNESSES: frozenset[str] = _rs_mod.KNOWN_HARNESSES

GLOBAL_PATH = Path(os.path.expanduser("~/.agentic/role-models.yml"))
ROLES = [
    "conductor", "investigator", "architect", "orchestration-planner",
    "engineer", "debugger", "qa-engineer", "skeptic", "security-auditor",
]

BANNER = (
    "agentic-configure: first-time role-model setup\n"
    "Press Enter to accept each default. Type a model id to override.\n"
    "Type 'skip' to leave the role unset (Pi uses session default).\n"
)


def _ask(prompt: str, default: str) -> str:
    """Prompt the user; return the typed string or `default` on empty input."""
    try:
        raw = input(f"{prompt} [{default}]: ").strip()
    except EOFError:
        return default
    if not raw:
        return default
    if raw.lower() == "skip":
        return ""
    return raw


def _ask_effort(default: str = "medium") -> str:
    return _ask("  effort (low/medium/high/xhigh or skip)", default)


def _ask_reasoning(default: str = "") -> str:
    return _ask("  reasoning (token budget, 'enabled', or skip)", default)


def _emit_yaml(roles: dict) -> str:
    """Render a roles dict into a YAML block."""
    lines = [
        "# Generated by agentic-configure.",
        "# Edit ~/.agentic/role-models.yml freely.",
        "roles:",
    ]
    for role, spec in roles.items():
        if not spec:
            continue
        if isinstance(spec, str):
            lines.append(f"  {role}: {spec}")
        else:
            lines.append(f"  {role}:")
            for key, val in spec.items():
                lines.append(f"    {key}: {val}")
    lines.append("")
    lines.append("reviewers:")
    lines.append("  strategy: distinct-from-author")
    lines.append("  pool:")
    seen: set[str] = set()
    for role in ("skeptic", "security-auditor"):
        spec = roles.get(role)
        if isinstance(spec, str) and spec and spec not in seen:
            lines.append(f"    - {spec}")
            seen.add(spec)
        elif isinstance(spec, dict) and spec.get("model") and spec["model"] not in seen:
            lines.append(f"    - {spec['model']}")
            seen.add(spec["model"])
    if not seen:
        lines.append("    - sonnet  # edit to your preferred reviewer model")
    lines.append("  fallback: gpt-5  # edit if your harness uses a different default")
    lines.append("")
    return "\n".join(lines)


def _models_suggestions(models_csv: str) -> dict:
    """Call agentic-models --all-suggestions with the given model list.

    Returns a suggestions dict (same shape as _gather_roles expects) or {}
    on any failure. Non-fatal: callers fall back to sonnet defaults.
    """
    agentic_models = Path(__file__).parent / "agentic-models"
    if not agentic_models.is_file():
        return {}
    model_list = [m.strip() for m in models_csv.split(",") if m.strip()]
    if not model_list:
        return {}
    try:
        result = subprocess.run(
            [str(agentic_models), "--all-suggestions", "--json"] + model_list,
            capture_output=True, text=True, timeout=10,
        )
    except (subprocess.SubprocessError, OSError):
        return {}
    if result.returncode != 0:
        return {}
    try:
        return json.loads(result.stdout)
    except ValueError:
        return {}


def _gather_roles(suggestions: dict, non_interactive: bool) -> dict:
    """Ask the user for each role, or accept all defaults in non-interactive mode."""
    roles: dict = {}
    for role in ROLES:
        info = suggestions.get("roles", {}).get(role, {}) if suggestions else {}
        default = info.get("primary", "sonnet") if info else "sonnet"
        if non_interactive:
            # store bare scalar (matches pre-refactor behavior for effort==''&&reasoning=='')
            roles[role] = default
            continue
        print(f"\n[{role}]")
        print(f"  default: {default}")
        if info.get("alternates"):
            print(f"  alternates: {', '.join(info['alternates'])}")
        choice = _ask(f"  model for {role}", default)
        if not choice:
            continue
        if role == "conductor":
            roles[role] = choice
            continue
        effort = _ask_effort("medium")
        reasoning = _ask_reasoning("")
        if not effort and not reasoning:
            # bare model only - store as scalar to match pre-refactor output
            roles[role] = choice
            continue
        raw: dict = {"model": choice}
        if effort:
            raw["effort"] = effort
        if reasoning:
            raw["reasoning"] = reasoning
        roles[role] = normalize_role_spec(raw)
    return roles


# ---------------------------------------------------------------------------
# team subcommand: back-compat shim -> delegates to `agentic-team configure`
# ---------------------------------------------------------------------------

def _cmd_team(argv: list[str]) -> int:
    """Back-compat shim: delegate `agentic-configure team <args>` to
    `agentic-team configure <args>`, propagating the exit code.

    Resolves agentic-team as a sibling binary in the same bin/ directory.
    Both binaries must be 0755 co-located (standard install layout).
    """
    agentic_team = Path(__file__).parent / "agentic-team"
    if not agentic_team.is_file():
        print(
            "agentic-configure team: agentic-team binary not found at "
            f"{agentic_team}; install agentic-team to use the team subcommand",
            file=sys.stderr,
        )
        return 2
    try:
        result = subprocess.run(
            [str(agentic_team), "configure"] + argv,
            # inherit stdin/stdout/stderr so interactive mode, TTY detection,
            # and --path output all work transparently
        )
        return result.returncode
    except (subprocess.SubprocessError, OSError) as exc:
        print(f"agentic-configure team: failed to invoke agentic-team: {exc}", file=sys.stderr)
        return 2


def main(argv: list[str]) -> int:
    # Dispatch-on-argv shim: if the first positional argument is "team", route
    # to the team subcommand WITHOUT touching the existing argparse parser.
    # This preserves all existing flag-only behavior byte-for-byte.
    # Deliberate deviation from the plan's add_subparsers approach: using an
    # argv shim avoids disturbing the existing flag parser and reduces the
    # rebase surface against in-flight PRs (e.g. #256).
    if argv and argv[0] == "team":
        return _cmd_team(argv[1:])

    ap = argparse.ArgumentParser(
        prog="agentic-configure",
        description="Interactive setup of ~/.agentic/role-models.yml.",
    )
    ap.add_argument(
        "--models", default="",
        help="comma-separated model ids to rank for per-role suggestions "
             "(optional aid; uses agentic-models ranking)",
    )
    ap.add_argument("--force", action="store_true", help="re-run even if file exists")
    ap.add_argument("--non-interactive", action="store_true",
                    help="accept all defaults silently")
    ap.add_argument("--path", default=str(GLOBAL_PATH), help="output file path")
    args = ap.parse_args(argv)

    target = Path(args.path)
    if target.exists() and not args.force:
        return 0

    suggestions: dict = {}
    if args.models:
        suggestions = _models_suggestions(args.models)

    roles = _gather_roles(suggestions, non_interactive=args.non_interactive)

    target.parent.mkdir(parents=True, exist_ok=True)
    target.write_text(_emit_yaml(roles), encoding="utf-8")

    if not args.non_interactive:
        print(f"\nWrote {target}")
        print("Edit freely; the file is gitignored under the .agentic/ umbrella.")
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
