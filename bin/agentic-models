#!/usr/bin/env python3
"""
Purpose: Probe the configured AI harness for its available models and emit a
         ranked suggestion per agentic-engineering role. The conductor and the
         TUI wizard (`bin/agentic-configure`) read this output to seed
         `~/.agentic/role-models.yml` against models the user actually has.

Public API: agentic-models [--json] [--probe-url URL] [--probe-key KEY]
            [--suggest <role>] [--all-suggestions]
            Default mode prints a human-readable summary of every model and
            a one-line per-role recommendation. `--json` prints the structured
            payload (suitable for piping into the TUI or to `yq`).
            `--suggest <role>` prints only the recommendation for one role.
            Exit code 0 on a successful probe, 2 on probe failure, 3 on
            invalid arguments. Never writes to disk.

Upstream deps: Python 3 stdlib (json, os, sys, urllib, argparse).

Downstream consumers: content/references/model-discovery.md (full spec);
                      bin/agentic-configure (TUI; uses --json);
                      content/sections/04-risk-classification.md (Role-model
                      routing tier); content/references/role-models.md.

Failure modes: probe network failure -> exit 2 with a single error line.
               The script does NOT fall back to a hardcoded catalog when the
               probe fails. The user is told to set NINEROUTER_URL or pass
               --probe-url. This matches the "no hardcoded model IDs"
               stance in the role-models reference.

Performance: One HTTP GET per invocation. ~200 ms on a warm probe.
"""

from __future__ import annotations

import argparse
import json
import os
import sys
import urllib.error
import urllib.request
from typing import Any

# Heuristics for per-role ranking. These are *hints*, not opinions -- the
# model name is what determines the final pick, the score just orders them.
ROLE_HINTS: dict[str, dict[str, int]] = {
    "conductor":          {"opus": 5, "sonnet": 2, "haiku": -3, "gpt-5": 3, "gemini-2.5-pro": 2},
    "investigator":       {"haiku": 3, "sonnet": 2, "gpt-5": 1, "kimi-k2.5": 2, "kimi-k2.6": 3},
    "architect":          {"opus": 6, "gpt-5": 4, "gemini-2.5-pro": 3, "sonnet": 2},
    "orchestration-planner": {"opus": 5, "gpt-5": 4, "sonnet": 2, "haiku": -2},
    "engineer":           {"sonnet": 5, "haiku": 3, "opus": 3, "gpt-5": 3, "kimi-k2.6": 3, "kimi-k2.7": 3},
    "debugger":           {"sonnet": 4, "opus": 3, "gpt-5": 3, "haiku": 2, "kimi-k2.5-thinking": 4},
    "qa-engineer":        {"haiku": 4, "sonnet": 3, "opus": 1},
    "skeptic":            {"opus": 6, "gpt-5": 4, "gemini-2.5-pro": 3, "sonnet": 2, "kimi-k2.7": 3},
    "security-auditor":   {"opus": 7, "gpt-5": 5, "gemini-2.5-pro": 4, "sonnet": 2},
}

# Reviewer pool candidates -- the list the distinct-from-author / round-robin
# strategies can draw from. We bias toward capable but cheaper models so the
# antagonist is plausibly as good as the author without spending the most
# expensive model on every review. Substring match is case-insensitive.
REVIEWER_POOL_HINTS: dict[str, int] = {
    "opus": 4, "sonnet": 2, "haiku": -1,
    "gpt-5.5": 5, "gpt-5.4": 4, "gpt-5.3-codex": 3, "gpt-5": 4,
    "gemini-2.5-pro": 4, "gemini-3-pro-preview": 5, "gemini-2.5-flash": 2,
    "kimi-k2.7": 5, "kimi-k2.6": 4, "kimi-k2.5-thinking": 5, "kimi-latest": 3,
    "glm-5.2": 4, "glm-5.1": 3, "glm-4.7-flash": 2,
    "deepseek-v4": 3, "deepseek-r1": 3,
}

ROLES = list(ROLE_HINTS.keys())


def _probe_models(url: str, key: str | None, timeout: int = 10) -> list[str]:
    """GET /v1/models and return the list of model id strings.

    `url` is the OpenAI-compatible base URL (e.g. https://9router.example or
    http://localhost:20128) WITHOUT a trailing /v1 suffix -- the /v1 is
    appended here, per the 9Router NINEROUTER_URL convention (see
    ~/.claude/skills/9router/SKILL.md). Exactly one trailing '/' on the base
    is stripped so both http://x and http://x/ yield http://x/v1/models.
    """
    base = (url[:-1] if url.endswith("/") else url) + "/v1/models"
    req = urllib.request.Request(base, method="GET")
    if key:
        req.add_header("Authorization", f"Bearer {key}")
    try:
        with urllib.request.urlopen(req, timeout=timeout) as resp:
            payload = json.loads(resp.read().decode("utf-8", errors="replace"))
    except (urllib.error.URLError, urllib.error.HTTPError, TimeoutError, json.JSONDecodeError) as exc:
        print(f"error: probe failed: {exc}", file=sys.stderr)
        sys.exit(2)
    data = payload.get("data", [])
    return [m["id"] for m in data if "id" in m]


def _score(model: str, hints: dict[str, int]) -> int:
    """Return a heuristic score for `model` against `hints`. Higher is better."""
    score = 0
    m = model.lower()
    for needle, delta in hints.items():
        if needle.lower() in m:
            score += delta
    # Tie-breakers: shorter / cleaner names win, all else equal
    if "preview" in m or "experimental" in m:
        score -= 1
    return score


def _rank(models: list[str], hints: dict[str, int]) -> list[tuple[str, int]]:
    return sorted(((m, _score(m, hints)) for m in models), key=lambda t: (-t[1], t[0]))


def _suggestions(models: list[str]) -> dict[str, Any]:
    """Return the structured suggestion payload."""
    out: dict[str, Any] = {"models": list(models), "roles": {}, "reviewer_pool": []}
    for role in ROLES:
        ranked = _rank(models, ROLE_HINTS[role])
        out["roles"][role] = {
            "primary": ranked[0][0] if ranked else None,
            "primary_score": ranked[0][1] if ranked else None,
            "alternates": [m for m, _ in ranked[1:4]],
        }
    pool_ranked = _rank(models, REVIEWER_POOL_HINTS)
    out["reviewer_pool"] = [m for m, s in pool_ranked if s > 0][:5]
    return out


def _print_human(payload: dict[str, Any], probe_url: str) -> None:
    print(f"Probe URL: {probe_url}")
    print(f"Models discovered: {len(payload['models'])}")
    print("")
    print("Per-role primary recommendation:")
    for role, info in payload["roles"].items():
        marker = " " if info["primary_score"] and info["primary_score"] > 0 else "?"
        print(f"  {marker} {role:<22} -> {info['primary'] or '(no match)'}")
    print("")
    print("Reviewer pool (distinct-from-author / round-robin candidates):")
    for m in payload["reviewer_pool"]:
        print(f"  - {m}")
    print("")
    print("Run with --json for the structured payload, or --suggest <role> for one role.")


    ap = argparse.ArgumentParser(
        prog="agentic-models",
        description="Probe the AI harness and rank models per agentic-engineering role.",
    )
    ap.add_argument("--json", action="store_true", help="emit structured JSON")
    ap.add_argument("--probe-url", default=os.environ.get("NINEROUTER_URL", ""),
                    help="OpenAI-compatible /v1 base URL (env: NINEROUTER_URL)")
    ap.add_argument("--probe-key",
                    default=os.environ.get("NINEROUTER_KEY") or os.environ.get("NINEROUTER_API_KEY", ""),
                    help="Bearer key (env: NINEROUTER_KEY; fallback NINEROUTER_API_KEY)")
    ap.add_argument("--suggest", choices=ROLES, help="print only one role's primary recommendation")
    ap.add_argument("--all-suggestions", action="store_true",
                    help="print the full ranking for every role")
    ap.add_argument("--timeout", type=int, default=10, help="HTTP timeout in seconds (default 10)")
    args = ap.parse_args(argv)

    if not args.probe_url:
        print("error: --probe-url or NINEROUTER_URL is required", file=sys.stderr)
        return 3

    models = _probe_models(args.probe_url, args.probe_key or None, timeout=args.timeout)
    payload = _suggestions(models)

    if args.json:
        json.dump(payload, sys.stdout, indent=2)
        sys.stdout.write("\n")
        return 0
    if args.suggest:
        info = payload["roles"][args.suggest]
        print(info["primary"] or "(no match)")
        return 0
    if args.all_suggestions:
        for role in ROLES:
            print(f"{role}:")
            for m, s in sorted(((m, _score(m, ROLE_HINTS[role])) for m in models),
                               key=lambda t: (-t[1], t[0]))[:5]:
                print(f"  {s:+d}  {m}")
        return 0
    _print_human(payload, args.probe_url)
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
