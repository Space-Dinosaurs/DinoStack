#!/usr/bin/env python3
"""
Purpose: Rank a caller-supplied list of AI model IDs per agentic-engineering
         role and emit a suggestion per role. The caller (conductor, TUI
         wizard, or shell) owns model discovery; this binary purely ranks
         whatever list it receives.

Public API: agentic-models [--json] [--suggest <role>] [--all-suggestions]
            [--models-from FILE] [model ...]
            Model IDs arrive via positional args, --models-from FILE (one id
            per line), or stdin (when piped). All three sources are combined.
            Empty input -> empty suggestions, exit 0.
            --json emits the structured payload (roles{} + reviewer_pool[]).
            --suggest <role> prints only the primary for one role.
            Exit code 0 on success; 2 on invalid arguments.
            Never writes to disk, never makes network calls.

Upstream deps: Python 3 stdlib (argparse, json, sys).

Downstream consumers: bin/agentic-configure (TUI; uses --json);
                      content/references/model-discovery.md (spec);
                      content/sections/04-risk-classification.md (tier);
                      content/references/role-models.md.

Failure modes: invalid argument -> exit 2. No network I/O; cannot fail due
               to connectivity. Empty model list -> suggestions with
               primary=None for every role; always exits 0.

Performance: Pure in-process scoring. <1 ms regardless of list length.
"""

from __future__ import annotations

import argparse
import json
import sys
from typing import Any

# Heuristics for per-role ranking. These are *hints*, not opinions -- the
# model name is what determines the final pick, the score just orders them.
ROLE_HINTS: dict[str, dict[str, int]] = {
    "conductor":          {"opus": 5, "sonnet": 2, "haiku": -3, "gpt-5": 3, "gemini-2.5-pro": 2},
    "investigator":       {"haiku": 3, "sonnet": 2, "gpt-5": 1, "kimi-k2.5": 2, "kimi-k2.6": 3},
    "architect":          {"opus": 6, "gpt-5": 4, "gemini-2.5-pro": 3, "sonnet": 2},
    "orchestration-planner": {"opus": 5, "gpt-5": 4, "sonnet": 2, "haiku": -2},
    "engineer":           {"sonnet": 5, "haiku": 3, "opus": 3, "gpt-5": 3, "kimi-k2.6": 3, "kimi-k2.7": 3},
    "debugger":           {"sonnet": 4, "opus": 3, "gpt-5": 3, "haiku": 2, "kimi-k2.5-thinking": 4},
    "qa-engineer":        {"haiku": 4, "sonnet": 3, "opus": 1},
    "skeptic":            {"opus": 6, "gpt-5": 4, "gemini-2.5-pro": 3, "sonnet": 2, "kimi-k2.7": 3},
    "security-auditor":   {"opus": 7, "gpt-5": 5, "gemini-2.5-pro": 4, "sonnet": 2},
}

# Reviewer pool candidates -- the list the distinct-from-author / round-robin
# strategies can draw from. We bias toward capable but cheaper models so the
# antagonist is plausibly as good as the author without spending the most
# expensive model on every review. Substring match is case-insensitive.
REVIEWER_POOL_HINTS: dict[str, int] = {
    "opus": 4, "sonnet": 2, "haiku": -1,
    "gpt-5.5": 5, "gpt-5.4": 4, "gpt-5.3-codex": 3, "gpt-5": 4,
    "gemini-2.5-pro": 4, "gemini-3-pro-preview": 5, "gemini-2.5-flash": 2,
    "kimi-k2.7": 5, "kimi-k2.6": 4, "kimi-k2.5-thinking": 5, "kimi-latest": 3,
    "glm-5.2": 4, "glm-5.1": 3, "glm-4.7-flash": 2,
    "deepseek-v4": 3, "deepseek-r1": 3,
}

ROLES = list(ROLE_HINTS.keys())


def _score(model: str, hints: dict[str, int]) -> int:
    """Return a heuristic score for `model` against `hints`. Higher is better."""
    score = 0
    m = model.lower()
    for needle, delta in hints.items():
        if needle.lower() in m:
            score += delta
    # Tie-breakers: shorter / cleaner names win, all else equal
    if "preview" in m or "experimental" in m:
        score -= 1
    return score


def _rank(models: list[str], hints: dict[str, int]) -> list[tuple[str, int]]:
    return sorted(((m, _score(m, hints)) for m in models), key=lambda t: (-t[1], t[0]))


def _suggestions(models: list[str]) -> dict[str, Any]:
    """Return the structured suggestion payload."""
    out: dict[str, Any] = {"models": list(models), "roles": {}, "reviewer_pool": []}
    for role in ROLES:
        ranked = _rank(models, ROLE_HINTS[role])
        out["roles"][role] = {
            "primary": ranked[0][0] if ranked else None,
            "primary_score": ranked[0][1] if ranked else None,
            "alternates": [m for m, _ in ranked[1:4]],
        }
    pool_ranked = _rank(models, REVIEWER_POOL_HINTS)
    out["reviewer_pool"] = [m for m, s in pool_ranked if s > 0][:5]
    return out


def _print_human(payload: dict[str, Any]) -> None:
    print(f"Models provided: {len(payload['models'])}")
    print("")
    print("Per-role primary recommendation:")
    for role, info in payload["roles"].items():
        marker = " " if info["primary_score"] and info["primary_score"] > 0 else "?"
        print(f"  {marker} {role:<22} -> {info['primary'] or '(no match)'}")
    print("")
    print("Reviewer pool (distinct-from-author / round-robin candidates):")
    for m in payload["reviewer_pool"]:
        print(f"  - {m}")
    print("")
    print("Run with --json for the structured payload, or --suggest <role> for one role.")


def _collect_models(args: argparse.Namespace) -> list[str]:
    """Gather model IDs from positional args, --models-from FILE, and stdin."""
    models: list[str] = list(args.models)

    if args.models_from:
        try:
            with open(args.models_from) as fh:
                for line in fh:
                    line = line.strip()
                    if line:
                        models.append(line)
        except OSError as exc:
            print(f"error: cannot read --models-from file: {exc}", file=sys.stderr)
            sys.exit(2)

    if not sys.stdin.isatty():
        for line in sys.stdin:
            line = line.strip()
            if line:
                models.append(line)

    # Deduplicate while preserving order
    seen: set[str] = set()
    deduped: list[str] = []
    for m in models:
        if m not in seen:
            seen.add(m)
            deduped.append(m)
    return deduped


def main(argv: list[str]) -> int:
    ap = argparse.ArgumentParser(
        prog="agentic-models",
        description=(
            "Rank a list of AI model IDs per agentic-engineering role. "
            "Provide models via positional args, --models-from FILE, or stdin."
        ),
    )
    ap.add_argument("models", nargs="*", metavar="MODEL",
                    help="model IDs to rank (e.g. opus sonnet gpt-5)")
    ap.add_argument("--models-from", metavar="FILE",
                    help="file of model IDs (one per line) to include in ranking")
    ap.add_argument("--json", action="store_true", help="emit structured JSON")
    ap.add_argument("--suggest", choices=ROLES,
                    help="print only one role's primary recommendation")
    ap.add_argument("--all-suggestions", action="store_true",
                    help="print the full ranking for every role")
    args = ap.parse_args(argv)

    models = _collect_models(args)
    payload = _suggestions(models)

    if args.json:
        json.dump(payload, sys.stdout, indent=2)
        sys.stdout.write("\n")
        return 0
    if args.suggest:
        info = payload["roles"][args.suggest]
        print(info["primary"] or "(no match)")
        return 0
    if args.all_suggestions:
        for role in ROLES:
            print(f"{role}:")
            for m, s in sorted(
                ((m, _score(m, ROLE_HINTS[role])) for m in models),
                key=lambda t: (-t[1], t[0]),
            )[:5]:
                print(f"  {s:+d}  {m}")
        return 0
    _print_human(payload)
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
