--- /dev/null
+++ b/src/pages/account/billing.tsx
@@ -0,0 +1,22 @@
+import { useState } from "react";
+
+export default function Billing() {
+  const [loading, setLoading] = useState(false);
+  const upgrade = async () => {
+    setLoading(true);
+    const res = await fetch("/api/stripe/checkout", { method: "POST" });
+    const { url } = await res.json();
+    window.location.href = url;
+  };
+  return (
+    <div>
+      <h1>Billing</h1>
+      <button onClick={upgrade} disabled={loading}>Upgrade</button>
+    </div>
+  );
+}
diff --git a/src/pages/api/stripe/checkout.ts b/src/pages/api/stripe/checkout.ts
new file mode 100644
index 0000000..aaabbbc
--- /dev/null
+++ b/src/pages/api/stripe/checkout.ts
@@ -0,0 +1,15 @@
+import Stripe from "stripe";
+const stripe = new Stripe(process.env.STRIPE_SECRET_KEY, { apiVersion: "2023-10-16" });
+
+export default async function handler(req, res) {
+  if (req.method !== "POST") return res.status(405).end();
+  const session = await stripe.checkout.sessions.create({
+    payment_method_types: ["card"],
+    line_items: [{ price: process.env.STRIPE_PRICE_ID, quantity: 1 }],
+    mode: "subscription",
+    success_url: `${process.env.APP_URL}/account/billing?status=success`,
+    cancel_url: `${process.env.APP_URL}/account/billing?status=cancel`,
+  });
+  return res.status(200).json({ url: session.url });
+}
diff --git a/src/pages/api/stripe/webhook.ts b/src/pages/api/stripe/webhook.ts
new file mode 100644
index 0000000..bcdbcde
--- /dev/null
+++ b/src/pages/api/stripe/webhook.ts
@@ -0,0 +1,20 @@
+import Stripe from "stripe";
+const stripe = new Stripe(process.env.STRIPE_SECRET_KEY, { apiVersion: "2023-10-16" });
+
+export default async function handler(req, res) {
+  const sig = req.headers["stripe-signature"];
+  const event = stripe.webhooks.constructEvent(req.rawBody, sig, process.env.STRIPE_WEBHOOK_SECRET);
+  if (event.type === "checkout.session.completed") {
+    const session = event.data.object;
+    await db.accounts.update(session.client_reference_id, { plan: "pro" });
+  }
+  return res.status(200).json({ received: true });
+}
