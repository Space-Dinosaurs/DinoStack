new file mode 100644
index 0000000..1c3f4e9
--- /dev/null
+++ b/src/ratelimit/bucket.py
@@ -0,0 +1,80 @@
+import os
+import time
+import redis
+
+
+class TokenBucket:
+    def __init__(self, client, capacity: int, refill_per_sec: float, prefix: str = "rl:"):
+        self.client = client
+        self.capacity = capacity
+        self.refill_per_sec = refill_per_sec
+        self.prefix = prefix
+
+    @classmethod
+    def from_env(cls):
+        url = os.environ["REDIS_URL"]
+        client = redis.Redis.from_url(url)
+        cap = int(os.environ.get("RL_CAPACITY", "60"))
+        rate = float(os.environ.get("RL_REFILL_PER_SEC", "1.0"))
+        return cls(client, cap, rate)
+
+    def _key(self, key: str) -> str:
+        return f"{self.prefix}{key}"
+
+    def refill(self, key: str) -> float:
+        k = self._key(key)
+        now = time.time()
+        pipe = self.client.pipeline()
+        pipe.hget(k, "tokens")
+        pipe.hget(k, "updated")
+        tokens_raw, updated_raw = pipe.execute()
+        tokens = float(tokens_raw) if tokens_raw is not None else float(self.capacity)
+        updated = float(updated_raw) if updated_raw is not None else now
+        elapsed = max(0.0, now - updated)
+        tokens = min(self.capacity, tokens + elapsed * self.refill_per_sec)
+        self.client.hset(k, mapping={"tokens": tokens, "updated": now})
+        return tokens
+
+    def allow(self, key: str) -> bool:
+        tokens = self.refill(key)
+        if tokens >= 1.0:
+            k = self._key(key)
+            self.client.hincrbyfloat(k, "tokens", -1.0)
+            return True
+        return False
+
+
+def middleware_factory(bucket: TokenBucket):
+    def _mw(request, call_next):
+        api_key = request.headers.get("x-api-key", "anon")
+        if not bucket.allow(api_key):
+            return _rate_limited_response()
+        return call_next(request)
+    return _mw
+
+
+def _rate_limited_response():
+    from starlette.responses import JSONResponse
+    return JSONResponse({"error": "rate_limited"}, status_code=429)
+
+
+def healthcheck(bucket: TokenBucket) -> dict:
+    try:
+        bucket.client.ping()
+        return {"ok": True}
+    except Exception as e:
+        return {"ok": False, "error": str(e)}
+
+
+def build_default() -> TokenBucket:
+    return TokenBucket.from_env()
+
+
+DEFAULT_CAPACITY = 60
+DEFAULT_REFILL = 1.0
+
+
+__all__ = ["TokenBucket", "middleware_factory", "healthcheck", "build_default"]
