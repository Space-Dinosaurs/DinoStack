+"""
+Purpose: File download endpoint serving authenticated users files from
+         FILE_STORE_DIR.
+
+Public API: download_file(request) -> FileResponse
+
+Upstream deps: starlette, os, config.FILE_STORE_DIR
+
+Downstream consumers: src/api/routes.py (registers the route)
+
+Failure modes: 404 if file missing. Auth is enforced upstream in middleware.
+
+Performance: streams file via FileResponse; no buffering.
+"""
+
+import os
+from starlette.responses import FileResponse, JSONResponse
+from src.config import FILE_STORE_DIR
+
+
+async def download_file(request):
+    name = request.path_params["name"]
+    target = os.path.join(FILE_STORE_DIR, name)
+    if not os.path.exists(target):
+        return JSONResponse({"error": "not_found"}, status_code=404)
+    return FileResponse(target)
