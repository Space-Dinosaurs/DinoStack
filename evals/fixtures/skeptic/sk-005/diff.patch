--- a/src/webhooks/stripe.py
+++ b/src/webhooks/stripe.py
@@ -12,6 +12,8 @@ def verify_webhook(request, body: bytes) -> bool:
     """Verify a Stripe webhook signature against the body."""
     sig = request.headers.get("Stripe-Signature")
+    if sig is None:
+        return False
     parts = dict(p.split("=", 1) for p in sig.split(","))
     t = parts.get("t")
     v1 = parts.get("v1")
