+"""
+Purpose: Server-side link preview: fetch a URL and extract og:title / og:image
+         so the chat client can render a rich card.
+
+Public API: preview(request) -> JSONResponse
+
+Upstream deps: httpx, beautifulsoup4
+
+Downstream consumers: src/api/routes.py
+
+Failure modes: returns {"error": "fetch_failed"} with status 502 on network
+               error. No auth enforced here (handled by middleware).
+
+Performance: one outbound GET per request, 5-second timeout.
+"""
+import httpx
+from bs4 import BeautifulSoup
+from starlette.responses import JSONResponse
+
+
+async def preview(request):
+    data = await request.json()
+    url = data.get("url")
+    if not url:
+        return JSONResponse({"error": "missing_url"}, status_code=400)
+    try:
+        async with httpx.AsyncClient(follow_redirects=True, timeout=5.0) as c:
+            resp = await c.get(url)
+    except httpx.HTTPError:
+        return JSONResponse({"error": "fetch_failed"}, status_code=502)
+    soup = BeautifulSoup(resp.text, "html.parser")
+    title = soup.find("meta", property="og:title")
+    image = soup.find("meta", property="og:image")
+    return JSONResponse(
+        {
+            "title": title["content"] if title else None,
+            "image": image["content"] if image else None,
+        }
+    )
