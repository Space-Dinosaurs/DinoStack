diff --git a/src/billing/pricing.py b/src/billing/pricing.py
index fffffff..1a1a1a1 100644
--- a/src/billing/pricing.py
+++ b/src/billing/pricing.py
@@ -1,5 +1,5 @@
 """
-Purpose: Compute the charge amount for a given subscriber + usage record.
+Purpose: Compute the charge amount for a given subscriber + usage record, including the free-tier rebate.

 Public API: compute_charge(subscriber, usage) -> int (cents)
 """
@@ -13,6 +13,12 @@ def compute_charge(subscriber, usage) -> int:
     if subscriber.plan == "enterprise":
         return max(0, base - subscriber.enterprise_credit_cents)
     if subscriber.plan == "pro":
         return base
+    if subscriber.plan == "free":
+        # Free tier gets a flat 100% rebate on the first 100 units, charged
+        # at the standard rate after that.
+        overage = max(0, usage.units - 100)
+        return overage * usage.rate_cents
+    # Fallback: treat unknown plans as pro pricing.
     return base
