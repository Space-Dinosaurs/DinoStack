+        refund = session.query(Refund).filter(Refund.order_id == o.id).order_by(Refund.created_at.desc()).first()
+        net = o.total_cents - (refund.amount_cents if refund else 0)
+        enriched.append({"order_id": o.id, "net_cents": net})
+    total_cents = sum(e["net_cents"] for e in enriched)
     return {
         "customer_id": customer_id,
         "month": month,
