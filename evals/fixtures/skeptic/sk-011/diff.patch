diff --git a/src/jobs/monthly_statement.py b/src/jobs/monthly_statement.py
index 4d4d4d4..5e5e5e5 100644
--- a/src/jobs/monthly_statement.py
+++ b/src/jobs/monthly_statement.py
@@ -10,10 +10,17 @@ def build_statement(session, customer_id: int, month: str) -> dict:
     orders = session.query(Order).filter(
         Order.customer_id == customer_id,
         Order.billing_month == month,
     ).all()

-    total_cents = sum(o.total_cents for o in orders)
+    enriched = []
+    for o in orders:
+        # Look up the latest refund amount per order so the statement
