+++ b/src/api/paginate.py
@@ -0,0 +1,26 @@
+"""
+Purpose: Offset+limit pagination helper used by list endpoints.
+
+Public API: paginate(query, page: int, page_size: int) -> dict
+
+Upstream deps: sqlalchemy Query
+
+Downstream consumers: src/api/list_orders.py, src/api/list_invoices.py
+
+Failure modes: raises ValueError on page < 1 or page_size < 1.
+
+Performance: one COUNT avoided; single SELECT with OFFSET + LIMIT.
+"""
+
+
+def paginate(query, page: int, page_size: int) -> dict:
+    if page < 1 or page_size < 1:
+        raise ValueError("page and page_size must be positive")
+    offset = (page - 1) * page_size
+    rows = query.offset(offset).limit(page_size).all()
+    return {
+        "page": page,
+        "page_size": page_size,
+        "items": rows,
+        "has_next": len(rows) == page_size,
+    }
diff --git a/tests/api/test_paginate.py b/tests/api/test_paginate.py
new file mode 100644
index 0000000..7a7a7a7
--- /dev/null
+++ b/tests/api/test_paginate.py
@@ -0,0 +1,21 @@
+from src.api.paginate import paginate
+from tests.factories import make_query
+
+
+def test_paginate_first_page_has_next():
+    # 25 total items, page_size 10: page 1 has 10, there are more.
+    q = make_query(total=25)
+    r = paginate(q, page=1, page_size=10)
+    assert len(r["items"]) == 10
+    assert r["has_next"] is True
+
+
+def test_paginate_last_partial_page_no_next():
+    # 25 total items, page_size 10: page 3 has 5, no more.
+    q = make_query(total=25)
+    r = paginate(q, page=3, page_size=10)
+    assert len(r["items"]) == 5
+    assert r["has_next"] is False
