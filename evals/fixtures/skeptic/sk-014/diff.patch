diff --git a/src/util/money.py b/src/util/money.py
index 1d1d1d1..2e2e2e2 100644
--- a/src/util/money.py
+++ b/src/util/money.py
@@ -1,6 +1,7 @@
 """
 Purpose: Small money-arithmetic helpers used across billing and reporting.

-Public API: cents_to_dollars(n: int) -> str
+Public API: cents_to_dollars(n: int) -> str,
+            format_signed_cents(n: int) -> str

 Upstream deps: stdlib only.

@@ -11,3 +12,11 @@ Performance: pure, O(1) per call.
 def cents_to_dollars(n: int) -> str:
     return f"${n / 100:.2f}"
+
+
+def format_signed_cents(n: int) -> str:
+    """Render an integer cent amount with an explicit sign and two decimals."""
+    sign = "-" if n < 0 else "+"
+    magnitude = abs(n) / 100
+    return f"{sign}${magnitude:.2f}"
