#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(git rev-parse --show-toplevel)"

# Detect worktree context - skip gracefully
GIT_COMMON=$(git rev-parse --git-common-dir)
GIT_DIR=$(git rev-parse --git-dir)
if [[ "$GIT_COMMON" != "$GIT_DIR" ]]; then
  echo "[pre-commit] Worktree detected - skipping builds."
  exit 0
fi

# Only run if content/ files were modified
if git diff --cached --name-only | grep -q "^content/"; then
  echo "[pre-commit] content/ changes detected - running builds..."
  bash "$REPO_DIR/.claude/build.sh"
  bash "$REPO_DIR/.codex/build.sh"
  bash "$REPO_DIR/.cursor/build.sh"
  bash "$REPO_DIR/.gemini/build.sh"
  bash "$REPO_DIR/.hermes/build.sh"
  bash "$REPO_DIR/.kimi/build.sh"
  bash "$REPO_DIR/.omp/build.sh"
  bash "$REPO_DIR/.openclaw/build.sh"
  bash "$REPO_DIR/.opencode/build.sh"
  bash "$REPO_DIR/.pi/build.sh"

  # Stage generated files
  git add \
    "$REPO_DIR/.claude/commands/"*.md \
    "$REPO_DIR/.claude/skills/agentic-engineering/METHODOLOGY.md" \
    "$REPO_DIR/.codex/AGENTS.md" \
    "$REPO_DIR/.codex/agents/"*.toml \
    "$REPO_DIR/.codex/references/"*.md \
    "$REPO_DIR/.codex/commands/"*.md \
    "$REPO_DIR/.cursor/rules/"*.mdc \
    "$REPO_DIR/.cursor/references/"*.md \
    "$REPO_DIR/.cursor/commands/"*.md \
    "$REPO_DIR/.gemini/GEMINI.md" \
    "$REPO_DIR/.gemini/references/"*.md \
    "$REPO_DIR/.gemini/commands/"*.toml \
    "$REPO_DIR/.gemini/agents/"*.md \
    "$REPO_DIR/.hermes/SKILL.md" \
    "$REPO_DIR/.kimi/AGENTS.md" \
    "$REPO_DIR/.kimi/skills/agentic-engineering/sections" \
    "$REPO_DIR/.omp/skills/agentic-engineering/references" \
    "$REPO_DIR/.omp/skills/agentic-engineering/rules" \
    "$REPO_DIR/.omp/skills/agentic-engineering/commands" \
    "$REPO_DIR/.omp/skills/agentic-engineering/agents" \
    "$REPO_DIR/.openclaw/skills" \
    "$REPO_DIR/.opencode/skills/agentic-engineering/METHODOLOGY.md" \
    "$REPO_DIR/.opencode/agents/"*.md \
    "$REPO_DIR/.opencode/commands/"*.md \
    "$REPO_DIR/.pi/skills/agentic-engineering/METHODOLOGY.md" \
    "$REPO_DIR/.pi/skills/agentic-engineering/SKILL.md" \
    "$REPO_DIR/.pi/prompts/"*.md

  echo "[pre-commit] Generated files staged."
fi

# Update last-updated date on hub page if docs/ or content/ changed
if git diff --cached --name-only | grep -qE '^(docs/|content/)'; then
  sed -i '' "s/Last updated: .*/Last updated: $(date +'%b %d, %Y')/" \
    "$REPO_DIR/docs/index.html"
  git add "$REPO_DIR/docs/index.html"
  echo "[pre-commit] Hub page last-updated date stamped."
fi

# Remind about docs updates when content/ changes without docs/ changes
if git diff --cached --name-only | grep -q "^content/"; then
  if ! git diff --cached --name-only | grep -q "^docs/"; then
    CHANGED=$(git diff --cached --name-only | grep "^content/" | sed 's|content/||' | head -5)
    echo ""
    echo "[pre-commit] NOTE: content/ changed but no docs/ files are staged."
    echo "  Changed: $CHANGED"
    echo "  Consider whether docs/index.html or docs/slides/ need updating."
    echo "  (This is a reminder, not a blocker.)"
    echo ""
  fi
fi

# ---------------------------------------------------------------------------
# Static analysis gates (warn-and-skip when tool absent, matching hook style)
# ---------------------------------------------------------------------------

# Only run when bin/ or hooks/ Python/JS files are staged.
STAGED_PY=$(git diff --cached --name-only | grep -E '^(bin/|hooks/).*\.py$|^bin/agentic-' | grep -v '/tests/' | grep -v '/lib/' || true)
STAGED_JS=$(git diff --cached --name-only | grep -E '^hooks/.*\.js$' | grep -v '/tests/' | grep -v '\.test\.js$' || true)

# ruff lint (Python CLIs + hooks)
if [ -n "$STAGED_PY" ]; then
  if command -v ruff >/dev/null 2>&1; then
    echo "[pre-commit] Running ruff check on bin/ hooks/..."
    if ! ruff check bin/ hooks/ 2>&1; then
      echo "[pre-commit] ruff check failed - commit blocked."
      exit 1
    fi
    echo "[pre-commit] ruff check passed."
  else
    echo "[pre-commit] WARNING: ruff not found - skipping Python lint (install: pip install ruff)."
  fi
fi

# mypy type-check (Python CLIs + hooks)
if [ -n "$STAGED_PY" ]; then
  if command -v mypy >/dev/null 2>&1; then
    echo "[pre-commit] Running mypy on bin/ hooks/..."
    MYPY_PY_ARGS=(
      bin/agentic-calibrate bin/agentic-cost bin/agentic-disable bin/agentic-doctor
      bin/agentic-help bin/agentic-identity bin/agentic-memory bin/agentic-migrate
      bin/agentic-parse-subagent-usage bin/agentic-status bin/agentic-update
      hooks/enforce-askuserquestion-default.py hooks/enforce-background-spawn.py
      hooks/enforce-no-abdication.py hooks/enforce-orchestrator-singularity.py
    )
    if ! mypy "${MYPY_PY_ARGS[@]}" --config-file pyproject.toml --scripts-are-modules 2>&1; then
      echo "[pre-commit] mypy check failed - commit blocked."
      exit 1
    fi
    echo "[pre-commit] mypy passed."
  else
    echo "[pre-commit] WARNING: mypy not found - skipping type-check (install: pip install mypy)."
  fi
fi

# ESLint (JS hooks)
if [ -n "$STAGED_JS" ]; then
  if command -v npx >/dev/null 2>&1 && [ -f "$REPO_DIR/node_modules/.bin/eslint" ]; then
    echo "[pre-commit] Running eslint on hooks/*.js..."
    if ! npx eslint hooks/*.js 2>&1; then
      echo "[pre-commit] eslint failed - commit blocked."
      exit 1
    fi
    echo "[pre-commit] eslint passed."
  else
    echo "[pre-commit] WARNING: eslint not found - skipping JS lint (install: npm install --save-dev eslint@8)."
  fi
fi
